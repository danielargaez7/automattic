# AI Provider: "gemini" (default) or "anthropic"
AI_PROVIDER=gemini

# Gemini (primary — supports multimodal image analysis)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-001

# Anthropic (automatic fallback if Gemini fails)
ANTHROPIC_API_KEY=your-anthropic-api-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3333

# WordPress.com OAuth (optional — enables "Publish to WordPress.com" flow)
# Register your app at https://developer.wordpress.com/apps/
# Set the redirect URI to: http://localhost:3333/api/auth/wordpress/callback
WORDPRESS_CLIENT_ID=your-wp-client-id
WORDPRESS_CLIENT_SECRET=your-wp-client-secret
NEXT_PUBLIC_WORDPRESS_CLIENT_ID=your-wp-client-id
